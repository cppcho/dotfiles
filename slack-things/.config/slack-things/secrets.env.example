# Copy to `secrets.env` (gitignored) and fill in. Both tokens are required.

# Bot token (starts with xoxb-) from OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...

# App-level token (starts with xapp-) with the connections:write scope,
# created under Basic Information -> App-Level Tokens
SLACK_APP_TOKEN=xapp-...

# Optional: emoji (without colons) that triggers a sync. Default: bookmark
# THINGS_EMOJI=bookmark

# Optional: only sync reactions added by you. Your Slack member ID (Uxxxxxxxx).
# SLACK_USER_ID=U0123456789

# Optional: drop new to-dos into a specific Things list/project instead of Inbox
# THINGS_LIST=Reading

# Optional: comma-separated Things tags to apply
# THINGS_TAGS=slack,follow-up
