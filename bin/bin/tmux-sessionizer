#!/usr/bin/env bash

# Ref from https://github.com/ThePrimeagen/.dotfiles/blob/master/bin/.local/scripts/tmux-sessionizer

cmd=""
fzf_prompt=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --cmd) cmd="$2"; shift 2 ;;
        --prompt) fzf_prompt="$2"; shift 2 ;;
        *) break ;;
    esac
done

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$({
        # Build associative arrays for O(1) lookups instead of per-dir subprocess spawning
        declare -A session_ts bell_set zscores
        while read -r ts name; do
            session_ts[$name]=$ts
        done < <(tmux list-sessions -F '#{session_last_attached} #{session_name}' 2>/dev/null)
        while read -r name flag; do
            [[ $flag == "1" ]] && bell_set[$name]=1
        done < <(tmux list-windows -a -F '#{session_name} #{window_bell_flag}' 2>/dev/null)
        if [[ -f ~/.z ]]; then
            while IFS='|' read -r zdir zscore _; do
                zscores[$zdir]=$zscore
            done < ~/.z
        fi
        # Directories are sorted into three tiers, displayed in this order:
        #   1. active_bell  — sessions with bell (unseen activity), sorted by last-attached time (newest first)
        #   2. active       — sessions without bell, sorted by last-attached time (newest first)
        #   3. inactive     — dirs with no tmux session, sorted by z frecency score or atime (highest first)
        active_bell="" active="" inactive=""
        while IFS= read -r dir; do
            [[ -d "$dir" ]] || continue
            name=${dir##*/}
            name=${name//./_}
            ts=${session_ts[$name]:-}
            if [[ -n "$ts" ]]; then
                if [[ -n "${bell_set[$name]:-}" ]]; then
                    active_bell+="$ts $dir 󰂞"$'\n'
                else
                    active+="$ts $dir ●"$'\n'
                fi
            else
                if [[ -f ~/.z ]]; then
                    inactive+="${zscores[$dir]:-0} $dir"$'\n'
                else
                    ats=$(stat -f '%a' "$dir" 2>/dev/null || echo "0")
                    inactive+="$ats $dir"$'\n'
                fi
            fi
        done < <(
            IFS=':' read -ra _tsz_paths <<< "${TMUX_SESSIONIZER_PATHS:-$HOME/dev/}"
            for p in "${_tsz_paths[@]}"; do
                p="${p/#\~/$HOME}"
                if [[ "$p" == */ ]]; then
                    find -L "${p%/}" -mindepth 1 -maxdepth 1 -type d
                else
                    [[ -d "$p" ]] && echo "$p"
                fi
            done
        )
        # Output tiers in priority order; sort -rn within each tier, then strip the numeric prefix
        echo "$active_bell" | sort -rn | cut -d' ' -f2-
        echo "$active" | sort -rn | cut -d' ' -f2-
        echo "$inactive" | sort -rn | cut -d' ' -f2-
    } | sed '/^$/d' | awk -v cwd="$PWD" '
        !found && $1 == cwd { first = $0; found = 1; next }
        { rest[++n] = $0 }
        END { if (first) print first; for (i = 1; i <= n; i++) print rest[i] }
    ' | fzf --exact --no-sort --tmux center,70% --prompt="${fzf_prompt:-Session > }")
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected="${selected% 󰂞}"
selected="${selected% ●}"
selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s $selected_name -c $selected
    exit 0
fi

if ! tmux has-session -t=$selected_name 2> /dev/null; then
    tmux new-session -ds $selected_name -c $selected
fi

if [[ -n "$cmd" ]]; then
    tmux new-window -t "$selected_name" -c "$selected" "$cmd"
    if [[ -n $TMUX ]]; then
        tmux switch-client -t "$selected_name"
    else
        tmux attach-session -t "$selected_name"
    fi
elif [[ -z $TMUX ]]; then
    tmux attach-session -t $selected_name
else
    tmux switch-client -t $selected_name
fi
