#!/usr/bin/env bash
# Herdr-side half of vim-aware pane navigation (the herdr equivalent of the
# tmux is_vim bindings). Bound to ctrl+h/j/k/l as herdr custom commands:
# forwards the chord to vim/fzf panes, otherwise moves herdr pane focus.
# The vim side lives in nvim/lua/plugins/tmux-navigator.lua.
#
# Runs on every keypress, so it talks to the herdr socket with nc instead of
# spawning the herdr CLI. The server answers one request per connection, so
# each request is its own nc call.

dir="${1:?usage: herdr-navigate left|down|up|right}"
case "$dir" in
  left)  key="ctrl+h" ;;
  down)  key="ctrl+j" ;;
  up)    key="ctrl+k" ;;
  right) key="ctrl+l" ;;
  *) echo "bad direction: $dir" >&2; exit 1 ;;
esac

pane="${HERDR_ACTIVE_PANE_ID:?not run from a herdr keybinding}"
sock="${HERDR_SOCKET_PATH:-$HOME/.config/herdr/herdr.sock}"

req() { printf '%s\n' "$1" | nc -U "$sock"; }

# Ask for the pane's process info; retry once on an empty reply to ride out a
# transient socket hiccup (this runs on every ctrl+hjkl press).
proc_req="{\"id\":\"1\",\"method\":\"pane.process_info\",\"params\":{\"pane_id\":\"$pane\"}}"
info=$(req "$proc_req")
[[ -z $info ]] && info=$(req "$proc_req")

# Forward the chord if a foreground process is vim/fzf; else move herdr focus.
# process_info reports only the pane's FOREGROUND processes, so matching the raw
# reply is correct (a Ctrl-Z'd vim has left the foreground group) and avoids a
# jq spawn on this per-keypress hot path. It also catches fzf run as a pipeline
# tail (herdr-sessionizer), since fzf is foreground even when not the pgid
# leader. Names = the tmux is_vim set plus fzf, anchored by the JSON quotes.
vim_re='"name":"g?\.?(view|l?n?vim?x?|fzf)(diff)?(-wrapped)?"'

if [[ $info =~ $vim_re ]]; then
  req "{\"id\":\"2\",\"method\":\"pane.send_keys\",\"params\":{\"pane_id\":\"$pane\",\"keys\":[\"$key\"]}}" >/dev/null
else
  req "{\"id\":\"2\",\"method\":\"pane.focus_direction\",\"params\":{\"direction\":\"$dir\"}}" >/dev/null
fi
