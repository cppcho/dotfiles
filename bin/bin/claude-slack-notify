#!/usr/bin/env bash
# Unified "Claude needs you" notifier: macOS banner + tmux bell + Slack DM.
# Wired into the PermissionRequest, AskUserQuestion PreToolUse, and Stop hooks
# (see ~/.claude/settings.json). Reads the hook JSON payload on stdin and builds
# a detail line describing exactly what Claude wants, so the notification shows
# the full command / question instead of just the tool name.
#
# An optional first arg labels the event ("stop" for the Stop hook); without it
# the script assumes a permission/question request.
#
# The Slack DM needs these two values. Hooks run in a non-interactive shell that
# does NOT source ~/.zshrc, so we self-load them from ~/.zshrc_private when they
# aren't already exported. Slack stays a no-op if they can't be found.
#   SLACK_BOT_TOKEN        Slack bot token (xoxb-...)
#   CLAUDE_SLACK_DM_TARGET Slack member ID (U...) of the DM recipient (you).
#
# To wire this into a fresh machine, paste this prompt into Claude Code:
#   "In ~/.claude/settings.json, add hooks that run ~/bin/claude-slack-notify:
#    on PermissionRequest, on PreToolUse matching AskUserQuestion, and on Stop
#    as `~/bin/claude-slack-notify stop`."
set -uo pipefail

event="${1:-}"
input=$(cat)

# Pull the Slack creds from ~/.zshrc_private (grep just the two exports so we
# don't run the rest of the file). They're static literals, so this is cheap.
if [ -z "${SLACK_BOT_TOKEN:-}" ] && [ -f "$HOME/.zshrc_private" ]; then
  eval "$(grep -E '^export (SLACK_BOT_TOKEN|CLAUDE_SLACK_DM_TARGET)=' "$HOME/.zshrc_private" 2>/dev/null)"
fi

tool=$(printf '%s' "$input" | jq -r '.tool_name // "tool"')
cwd=$(printf '%s' "$input" | jq -r '.cwd // ""')
proj="${cwd:-$PWD}"
proj="${proj/#$HOME/\~}"  # collapse home to ~ (e.g. ~/dev/zp-cppcho)

# Session title: a /rename custom title wins, else the auto topic title, else
# the last user prompt. Lets the ping say which session it came from.
transcript=$(printf '%s' "$input" | jq -r '.transcript_path // ""')
session=""
last_msg=""
if [ -n "$transcript" ] && [ -f "$transcript" ]; then
  last_of() { grep -hE "\"type\":\"$1\"" "$transcript" 2>/dev/null | tail -1 | jq -r ".$2 // empty" 2>/dev/null; }
  session=$(last_of custom-title customTitle)
  [ -n "$session" ] || session=$(last_of ai-title aiTitle)
  [ -n "$session" ] || session=$(last_of last-prompt lastPrompt)
  # The last thing Claude actually said (its final text, skipping tool calls),
  # capped so a long final message doesn't make a giant notification.
  last_msg=$(jq -rs '
    [.[] | select(.type=="assistant") | .message.content[]? | select(.type=="text") | .text]
    | map(select(. != "")) | (last // "") | .[0:1500]' "$transcript" 2>/dev/null)
fi

# Human-readable detail describing what Claude is waiting on:
#   Bash            -> the full command, plus its description
#   AskUserQuestion -> the question(s) being asked
#   file tools      -> the file path
#   fallback        -> the notification message, else empty
detail=$(printf '%s' "$input" | jq -r '
  if .tool_name == "Bash" then
    (.tool_input.command // "")
    + (if (.tool_input.description // "") != "" then "\n— " + .tool_input.description else "" end)
  elif .tool_name == "AskUserQuestion" then
    (.tool_input.questions // [] | map(.question) | join("\n\n"))
  elif (.tool_input.file_path // "") != "" then
    .tool_input.file_path
  elif (.message // "") != "" then
    .message
  else
    ""
  end
')

# context = what Claude last said (only for Stop, to recap the finished turn);
# action  = the command / question Claude wants to run (permission & question);
# body    = the one-liner for the macOS banner.
context=""
action=""
if [ "$event" = "stop" ]; then
  icon=":white_check_mark:"
  title="Claude finished"
  context="${last_msg:-Turn complete — back to you}"
  body="$context"
elif [ "$tool" = "AskUserQuestion" ]; then
  icon=":question:"
  title="Claude is asking"
  action="${detail:-$tool}"
  body="$action"
else
  icon=":warning:"
  title="Claude needs permission: ${tool}"
  action="${detail:-$tool}"
  body="$action"
fi

# tmux pane bell
~/bin/tmux-bell 2>/dev/null || true

# macOS banner (subtitle carries the session title + project for context;
# collapse newlines in the body so it stays on one tidy line)
if command -v terminal-notifier >/dev/null 2>&1; then
  sub="$proj"
  [ -n "$session" ] && sub="$session · $proj"
  banner=$(printf '%s' "$body" | tr '\n' ' ')
  terminal-notifier -title "$title" -subtitle "$sub" \
    -message "$banner" -sound Glass -activate com.mitchellh.ghostty 2>/dev/null || true
fi

# Slack DM (fire-and-forget so a slow/offline network never blocks Claude's turn)
if [ -n "${SLACK_BOT_TOKEN:-}" ] && [ -n "${CLAUDE_SLACK_DM_TARGET:-}" ]; then
  header=$(printf '%s [%s] *%s*' "$icon" "$(date '+%H:%M')" "$title")
  if [ -n "$session" ]; then
    header=$(printf '%s in "_%s_" (`%s`)' "$header" "$session" "$proj")
  else
    header=$(printf '%s in `%s`' "$header" "$proj")
  fi

  # Build the payload with jq so all JSON escaping is handled. The context (last
  # message) and action (command / question) each go in a rich_text_preformatted
  # block, which renders literally — so backticks, quotes, or newlines can never
  # break the formatting. Blocks are only added when their text is non-empty.
  payload=$(jq -n \
    --arg c "$CLAUDE_SLACK_DM_TARGET" --arg h "$header" \
    --arg ctx "$context" --arg act "$action" '
    def pre($t): {type: "rich_text", elements: [
      {type: "rich_text_preformatted", elements: [{type: "text", text: $t}]}
    ]};
    {
      channel: $c, text: $h,
      blocks: ([{type: "section", text: {type: "mrkdwn", text: $h}}]
        + (if $ctx != "" then [pre($ctx)] else [] end)
        + (if $act != "" then [pre($act)] else [] end))
    }')

  ( curl -sS -X POST https://slack.com/api/chat.postMessage \
      -H "Authorization: Bearer ${SLACK_BOT_TOKEN}" \
      -H 'Content-Type: application/json; charset=utf-8' \
      --data "$payload" >/dev/null 2>&1 & )
fi

exit 0
