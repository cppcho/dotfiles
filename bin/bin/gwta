#!/usr/bin/env bash
# Create a git worktree with a new branch tracking the default branch (main/master)

branch="$1"
if [[ -z "$branch" ]]; then
    echo "Usage: gwta <branch-name>"
    exit 1
fi

# Detect default branch
if git show-ref --verify --quiet refs/heads/main 2>/dev/null; then
    default_branch="main"
elif git show-ref --verify --quiet refs/heads/master 2>/dev/null; then
    default_branch="master"
else
    echo "Error: could not find main or master branch"
    exit 1
fi

repo=$(basename "$(git rev-parse --show-toplevel)")
worktree_path="../${repo}-${branch}"

git worktree add -b "$branch" "$worktree_path" "$default_branch"
