#!/usr/bin/env bash
# List all tmux panes running claude, pick one with fzf, jump to it

now=$(date +%s)
# Resolve claude symlink to match the actual binary name (e.g., 2.1.92)
claude_bin=$(basename "$(readlink "$(command -v claude)" 2>/dev/null)" 2>/dev/null)

format_age() {
  local diff=$1
  if [ "$diff" -lt 60 ]; then
    echo "${diff}s"
  elif [ "$diff" -lt 3600 ]; then
    echo "$((diff / 60))m"
  elif [ "$diff" -lt 86400 ]; then
    echo "$((diff / 3600))h"
  else
    echo "$((diff / 86400))d"
  fi
}

lines=$(tmux list-panes -a -F "#{window_activity}	#{window_bell_flag}	#{session_name}:#{window_index}.#{pane_index}	#{pane_current_command}	#{pane_title}" \
  | awk -F'\t' -v cb="$claude_bin" '$4 == "claude" || (cb != "" && $4 == cb)' \
  | sort -rn -t$'\t' -k1,1 \
  | while IFS=$'\t' read -r activity bell target cmd title; do
    age=$(format_age $((now - activity)))

    if [ "$bell" = "1" ]; then
      bell_icon="󰂞 "
    else
      bell_icon="  "
    fi

    # Strip spinner/status chars, remove generic titles
    clean_title=$(echo "$title" | sed 's/^[^[:alnum:]]* *//')
    case "$clean_title" in
      "Claude Code"|"zsh"|"bash"|"fish"|"sh") clean_title="" ;;
    esac

    session="${target%%:*}"
    printf "%s\t%s %-20s  %5s  %s\n" "$target" "$bell_icon" "$session" "$age" "$clean_title"
  done)

if [ -z "$lines" ]; then
  echo "No active Claude sessions found."
  echo ""
  echo "Press any key to close..."
  read -rsn1
  exit 0
fi

echo "$lines" \
  | fzf --no-sort --delimiter '\t' --with-nth 2 --prompt="Claude sessions > " \
  | cut -f1 \
  | xargs -I{} tmux switch-client -t {}
