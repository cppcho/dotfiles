#!/usr/bin/env bash
# Git worktree + tmux workflow helper
#
# Usage:
#   gwt [branch|#N|pr-url]  Switch to a worktree (fzf picker if no arg, create if needed)
#   gwt delete              Pick a worktree with fzf and remove it
#   gwt purge               Remove worktrees whose branches are merged
#   gwt setup               Open .gwt-setup in the repo root with $EDITOR
#
# Setup script:
#   Place a `.gwt-setup` file in your repo root (git-ignored).
#   It runs automatically when a new worktree is created.

set -e

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

get_main_worktree() {
    git worktree list --porcelain | head -1 | sed 's/^worktree //'
}

get_default_branch() {
    if git show-ref --verify --quiet refs/heads/main 2>/dev/null; then
        echo "main"
    elif git show-ref --verify --quiet refs/heads/master 2>/dev/null; then
        echo "master"
    else
        echo "Error: could not find main or master branch" >&2
        exit 1
    fi
}

# Find existing worktree path for a given branch name
find_worktree_for_branch() {
    local branch="$1"
    git worktree list --porcelain | awk -v branch="$branch" '
        /^worktree / { wt = substr($0, 10) }
        /^branch /   { b = substr($0, 8); sub(/^refs\/heads\//, "", b); if (b == branch) print wt }
    '
}

# Resolve a user-supplied ref to a branch name.
# Accepts a branch name, a PR number (#123 or 123), or a GitHub PR URL.
resolve_branch() {
    local input="$1"
    local pr_num=""

    # GitHub PR URL: https://github.com/owner/repo/pull/123
    if [[ "$input" =~ github\.com/[^/]+/[^/]+/pull/([0-9]+) ]]; then
        pr_num="${BASH_REMATCH[1]}"
    # Explicit PR form: #123
    elif [[ "$input" =~ ^#([0-9]+)$ ]]; then
        pr_num="${BASH_REMATCH[1]}"
    # Bare number: try as PR first, fall back to literal branch name
    elif [[ "$input" =~ ^[0-9]+$ ]]; then
        pr_num="$input"
    fi

    if [[ -n "$pr_num" ]]; then
        if ! command -v gh &>/dev/null; then
            if [[ "$input" != "$pr_num" ]]; then
                echo "Error: gh CLI is required to resolve PR $input" >&2
                return 1
            fi
        else
            local branch
            if branch=$(gh pr view "$pr_num" --json headRefName --jq .headRefName 2>/dev/null) \
                && [[ -n "$branch" ]]; then
                echo "$branch"
                return 0
            fi
            # Explicit PR syntax must resolve; bare number can fall through as branch
            if [[ "$input" != "$pr_num" ]]; then
                echo "Error: could not resolve PR $input via gh" >&2
                return 1
            fi
        fi
    fi

    echo "$input"
    return 0
}

# Check if a branch has been merged into the default branch.
# Handles fast-forward/merge commits (ancestor check) and squash/rebase
# merges (patch-equivalence via git cherry).
is_branch_merged() {
    local branch="$1"
    local default_branch="$2"

    # Prefer origin/<default> for freshness, fall back to local.
    local target=""
    if git rev-parse --verify "refs/remotes/origin/$default_branch" &>/dev/null; then
        target="refs/remotes/origin/$default_branch"
    elif git rev-parse --verify "refs/heads/$default_branch" &>/dev/null; then
        target="refs/heads/$default_branch"
    else
        return 1
    fi

    # Ancestor: normal or fast-forward merge.
    if git merge-base --is-ancestor "refs/heads/$branch" "$target" 2>/dev/null; then
        return 0
    fi

    # Patch-equivalent: squash or rebase merge. git cherry marks each commit
    # on $branch with '+' if absent from $target or '-' if already applied.
    local output
    output=$(git cherry "$target" "refs/heads/$branch" 2>/dev/null) || return 1
    [[ -z "$output" ]] && return 1
    if ! grep -q '^+' <<< "$output"; then
        return 0
    fi

    return 1
}

# Derive tmux session name from a worktree path
session_name_for_path() {
    local name
    name="$(basename "$1")"
    echo "${name//[.:]/-}"
}

# Kill the tmux session associated with a worktree path.
# If we're currently in that session, switch to the main repo session first.
kill_worktree_tmux_session() {
    local wt_path="$1"
    local main_worktree="$2"

    [[ -z "${TMUX:-}" ]] && return

    local session_name
    session_name=$(session_name_for_path "$wt_path")

    if ! tmux has-session -t "=$session_name" 2>/dev/null; then
        return
    fi

    # If we're in the session being killed, switch to main repo session first
    local current_session
    current_session=$(tmux display-message -p '#S')
    if [[ "$current_session" == "$session_name" ]]; then
        local main_session
        main_session=$(session_name_for_path "$main_worktree")
        # Create main session if it doesn't exist
        if ! tmux has-session -t "=$main_session" 2>/dev/null; then
            tmux new-session -d -s "$main_session" -c "$main_worktree"
        fi
        tmux switch-client -t "=$main_session"
    fi

    tmux kill-session -t "=$session_name"
    echo "Killed tmux session: $session_name"
}

run_setup_script() {
    local worktree_path="$1"
    local main_worktree
    main_worktree=$(get_main_worktree)
    local setup_script="${main_worktree}/.gwt-setup"

    if [[ -x "$setup_script" ]]; then
        echo "Running setup script: $setup_script"
        (cd "$worktree_path" && "$setup_script")
    elif [[ -f "$setup_script" ]]; then
        echo "Running setup script: $setup_script"
        (cd "$worktree_path" && bash "$setup_script")
    fi
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_switch() {
    local input="${1:-}"

    # No argument — fzf picker over existing worktrees
    if [[ -z "$input" ]]; then
        local selected
        selected=$(git worktree list --porcelain | awk '
            /^worktree / { wt = substr($0, 10) }
            /^branch /   { b = substr($0, 8); sub(/^refs\/heads\//, "", b); print b "\t" wt }
        ' | fzf --delimiter='\t' --with-nth=1 --preview 'echo {}' --prompt="Switch to worktree> ")

        if [[ -z "$selected" ]]; then
            return
        fi

        local branch wt_path
        branch=$(echo "$selected" | cut -f1)
        wt_path=$(echo "$selected" | cut -f2)

        open_in_tmux "$branch" "$wt_path"
        return
    fi

    # Argument given — create worktree if needed, then switch
    local branch
    branch=$(resolve_branch "$input") || exit 1
    if [[ "$branch" != "$input" ]]; then
        echo "Resolved $input → $branch"
    fi

    local main_worktree
    main_worktree=$(get_main_worktree)
    local repo
    repo=$(basename "$main_worktree")

    # Check if a worktree already exists for this branch
    local existing_wt
    existing_wt=$(find_worktree_for_branch "$branch")

    if [[ -n "$existing_wt" ]]; then
        # Worktree exists — open it in a tmux session
        echo "Worktree already exists: $existing_wt"
        open_in_tmux "$branch" "$existing_wt"
        return
    fi

    # Determine worktree path
    local wt_path="${main_worktree}/../${repo}-${branch}"

    # Path already exists on disk (e.g. stale/deregistered worktree) — just open it
    if [[ -d "$wt_path" ]]; then
        wt_path=$(cd "$wt_path" && pwd)
        echo "Directory already exists: $wt_path"
        open_in_tmux "$branch" "$wt_path"
        return
    fi

    # Check if branch exists (locally or in origin)
    if git show-ref --verify --quiet "refs/heads/${branch}" 2>/dev/null; then
        # Local branch exists — create worktree from it
        git worktree add "$wt_path" "$branch"
    elif git fetch origin "$branch" 2>/dev/null && \
         git show-ref --verify --quiet "refs/remotes/origin/${branch}" 2>/dev/null; then
        # Remote branch exists — create worktree tracking it
        git worktree add "$wt_path" "$branch"
    else
        # Branch doesn't exist — create from default branch
        local default_branch
        default_branch=$(get_default_branch)
        git worktree add -b "$branch" "$wt_path" "$default_branch"
    fi

    # Resolve to absolute path
    wt_path=$(cd "$wt_path" && pwd)

    # Run setup script for new worktrees
    run_setup_script "$wt_path"

    # Open in tmux
    open_in_tmux "$branch" "$wt_path"
}

cmd_delete() {
    local main_worktree
    main_worktree=$(get_main_worktree)
    local current_dir
    current_dir=$(pwd)

    # Build list of secondary worktrees for fzf
    local worktrees
    worktrees=$(git worktree list --porcelain | awk -v main="$main_worktree" '
        /^worktree / { wt = substr($0, 10) }
        /^branch /   { b = substr($0, 8); sub(/^refs\/heads\//, "", b); if (wt != main) print b "\t" wt }
    ')

    if [[ -z "$worktrees" ]]; then
        echo "No secondary worktrees to delete"
        exit 0
    fi

    # Find current worktree's branch to use as fzf default
    local current_branch=""
    while IFS=$'\t' read -r b wt; do
        if [[ "$current_dir" == "$wt"* ]]; then
            current_branch="$b"
            break
        fi
    done <<< "$worktrees"

    local fzf_opts=(--delimiter='\t' --with-nth=1 --prompt="Delete worktree> ")
    if [[ -n "$current_branch" ]]; then
        fzf_opts+=(--query="$current_branch" --select-1)
    fi

    local selected
    selected=$(echo "$worktrees" | fzf "${fzf_opts[@]}")

    if [[ -z "$selected" ]]; then
        return
    fi

    local branch wt_path
    branch=$(echo "$selected" | cut -f1)
    wt_path=$(echo "$selected" | cut -f2)

    echo "Removing worktree: $wt_path (branch: $branch)"

    # If we're inside the worktree being deleted, cd to main first
    if [[ "$current_dir" == "$wt_path"* ]]; then
        cd "$main_worktree"
        git worktree remove "$wt_path"
        echo "Switched to: $main_worktree"
        if [[ -n "${TMUX:-}" ]]; then
            tmux send-keys "cd '$main_worktree'" Enter
        fi
    else
        git worktree remove "$wt_path"
    fi

    # Kill associated tmux session (must be last — may kill our own process)
    kill_worktree_tmux_session "$wt_path" "$main_worktree"
}

cmd_setup() {
    local main_worktree
    main_worktree=$(get_main_worktree)
    local setup_script="${main_worktree}/.gwt-setup"

    "${EDITOR:-vim}" "$setup_script"
}

cmd_purge() {
    local main_worktree
    main_worktree=$(get_main_worktree)
    local default_branch
    default_branch=$(get_default_branch)

    # Refresh origin/<default> so squash-merged branches are detected.
    echo "Fetching origin/$default_branch..."
    git fetch origin "$default_branch" 2>/dev/null || true

    local entries=()
    while IFS=$'\t' read -r branch wt; do
        [[ -z "$branch" ]] && continue
        [[ "$wt" == "$main_worktree" ]] && continue
        [[ "$branch" == "$default_branch" ]] && continue

        if is_branch_merged "$branch" "$default_branch"; then
            entries+=("$branch"$'\t'"$wt")
        fi
    done < <(git worktree list --porcelain | awk '
        /^worktree / { wt = substr($0, 10) }
        /^branch /   { b = substr($0, 8); sub(/^refs\/heads\//, "", b); print b "\t" wt }
    ')

    if [[ ${#entries[@]} -eq 0 ]]; then
        echo "No merged worktrees to purge"
        return
    fi

    echo
    echo "Worktrees whose branch is merged into $default_branch:"
    for entry in "${entries[@]}"; do
        local b="${entry%%$'\t'*}"
        local w="${entry##*$'\t'}"
        printf "  %s  →  %s\n" "$b" "$w"
    done
    echo

    local reply
    read -rp "Remove these worktrees and delete their branches? (y/N) " reply
    if [[ "$reply" != "y" && "$reply" != "Y" ]]; then
        echo "Aborted"
        return
    fi

    # If we're inside one of the worktrees being removed, jump out first.
    local current_dir
    current_dir=$(pwd)
    local moved=0
    for entry in "${entries[@]}"; do
        local w="${entry##*$'\t'}"
        if [[ "$current_dir" == "$w"* ]]; then
            cd "$main_worktree"
            moved=1
            break
        fi
    done

    for entry in "${entries[@]}"; do
        local b="${entry%%$'\t'*}"
        local w="${entry##*$'\t'}"
        echo "Removing worktree: $w"
        if git worktree remove "$w" 2>/dev/null; then
            :
        else
            echo "  (worktree is dirty; retrying with --force)"
            git worktree remove --force "$w" || continue
        fi
        # Branch was verified as merged above, so force-delete is safe.
        git branch -D "$b" 2>/dev/null || true
    done

    if [[ "$moved" == "1" && -n "${TMUX:-}" ]]; then
        tmux send-keys "cd '$main_worktree'" Enter
    fi

    # Kill associated tmux sessions (must be last — may kill our own process)
    for entry in "${entries[@]}"; do
        local w="${entry##*$'\t'}"
        kill_worktree_tmux_session "$w" "$main_worktree"
    done
}

# ---------------------------------------------------------------------------
# Tmux session integration
# ---------------------------------------------------------------------------

open_in_tmux() {
    local branch="$1"
    local wt_path="$2"

    local session_name
    session_name=$(session_name_for_path "$wt_path")

    if [[ -z "${TMUX:-}" ]]; then
        # Not in tmux — create or attach to session
        if tmux has-session -t "=$session_name" 2>/dev/null; then
            tmux attach-session -t "=$session_name"
        else
            tmux new-session -s "$session_name" -c "$wt_path"
        fi
        return
    fi

    # Already in tmux — create or switch to session
    if tmux has-session -t "=$session_name" 2>/dev/null; then
        tmux switch-client -t "=$session_name"
    else
        tmux new-session -d -s "$session_name" -c "$wt_path"
        tmux switch-client -t "=$session_name"
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

# Ensure we're in a git repo
if ! git rev-parse --git-dir &>/dev/null; then
    echo "Error: not inside a git repository"
    exit 1
fi

case "${1:-}" in
    switch)        shift; cmd_switch "$@" ;;
    setup)         shift; cmd_setup "$@" ;;
    delete)        shift; cmd_delete "$@" ;;
    purge) shift; cmd_purge "$@" ;;
    -h|--help)
        echo "Usage: gwt [ref]"
        echo ""
        echo "Commands:"
        echo "  gwt [ref]      Switch to a worktree (fzf picker if no ref given)."
        echo "                 Creates the worktree if it doesn't exist."
        echo "                 <ref> may be a branch name, #PR, or PR URL."
        echo "  gwt delete     Pick a worktree with fzf and remove it"
        echo "  gwt purge      Remove worktrees whose branches are merged"
        echo "  gwt setup      Open .gwt-setup in \$EDITOR"
        echo ""
        echo "Setup:"
        echo "  Place a .gwt-setup script in your repo root."
        echo "  It runs automatically when a new worktree is created."
        exit 0
        ;;
    *)
        cmd_switch "$@" ;;
esac
