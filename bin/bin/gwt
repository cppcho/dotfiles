#!/usr/bin/env bash
# Git worktree + tmux/herdr workflow helper
#
# Runs under either multiplexer: each worktree gets its own tmux session or
# herdr workspace, chosen automatically based on where gwt is invoked.
#
# Usage:
#   gwt switch [branch|#N|pr-url]  Switch to a worktree (fzf picker if no arg, create if needed)
#   gwt delete [--force]            Pick a worktree with fzf and remove it
#   gwt purge                      Remove worktrees whose branches are merged
#   gwt setup                      Open .gwt-setup in the repo root with $EDITOR
#
# Setup script:
#   Place a `.gwt-setup` file in your repo root (git-ignored).
#   It runs automatically (in the background) when a new worktree is created;
#   output is logged to <worktree>/.gwt-setup.log.

set -e

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

get_main_worktree() {
    git worktree list --porcelain | head -1 | sed 's/^worktree //'
}

get_default_branch() {
    if git show-ref --verify --quiet refs/heads/main 2>/dev/null; then
        echo "main"
    elif git show-ref --verify --quiet refs/heads/master 2>/dev/null; then
        echo "master"
    else
        echo "Error: could not find main or master branch" >&2
        exit 1
    fi
}

# Directory that holds all gwt-created worktrees. Override with $GWT_WORKTREES_DIR.
# Worktrees are nested per repo as "<repo>/<slug>", so every repo's trees live
# under one root without colliding. git worktree add creates the <repo>/ dir;
# this just ensures the root exists.
worktrees_dir() {
    local dir="${GWT_WORKTREES_DIR:-$HOME/.worktrees}"
    mkdir -p "$dir"
    echo "$dir"
}

# Find existing worktree path for a given branch name
find_worktree_for_branch() {
    local branch="$1"
    git worktree list --porcelain | awk -v branch="$branch" '
        /^worktree / { wt = substr($0, 10) }
        /^branch /   { b = substr($0, 8); sub(/^refs\/heads\//, "", b); if (b == branch) print wt }
    '
}

# Clear a lock on a worktree if one is set. gwt-created worktrees can be locked
# by external tooling (e.g. a Claude Code session tags the tree with its PID);
# when that process dies the lock is left stale and blocks `git worktree remove`.
# Unlocking is a no-op when the tree isn't locked, so this is safe to call
# unconditionally before removal.
unlock_worktree() {
    git worktree unlock "$1" 2>/dev/null || true
}

# Resolve a user-supplied ref to a branch name.
# Accepts a branch name, a PR number (#123 or 123), or a GitHub PR URL.
resolve_branch() {
    local input="$1"
    local pr_num=""

    # GitHub PR URL: https://github.com/owner/repo/pull/123
    if [[ "$input" =~ github\.com/[^/]+/[^/]+/pull/([0-9]+) ]]; then
        pr_num="${BASH_REMATCH[1]}"
    # Explicit PR form: #123
    elif [[ "$input" =~ ^#([0-9]+)$ ]]; then
        pr_num="${BASH_REMATCH[1]}"
    # Bare number: try as PR first, fall back to literal branch name
    elif [[ "$input" =~ ^[0-9]+$ ]]; then
        pr_num="$input"
    fi

    if [[ -n "$pr_num" ]]; then
        if ! command -v gh &>/dev/null; then
            if [[ "$input" != "$pr_num" ]]; then
                echo "Error: gh CLI is required to resolve PR $input" >&2
                return 1
            fi
        else
            local branch
            if branch=$(gh pr view "$pr_num" --json headRefName --jq .headRefName 2>/dev/null) \
                && [[ -n "$branch" ]]; then
                echo "$branch"
                return 0
            fi
            # Explicit PR syntax must resolve; bare number can fall through as branch
            if [[ "$input" != "$pr_num" ]]; then
                echo "Error: could not resolve PR $input via gh" >&2
                return 1
            fi
        fi
    fi

    echo "$input"
    return 0
}

# Check if a branch has been merged into the default branch.
# Handles fast-forward/merge commits (ancestor check) and squash/rebase
# merges (patch-equivalence via git cherry).
is_branch_merged() {
    local branch="$1"
    local default_branch="$2"

    # Prefer origin/<default> for freshness, fall back to local.
    local target=""
    if git rev-parse --verify "refs/remotes/origin/$default_branch" &>/dev/null; then
        target="refs/remotes/origin/$default_branch"
    elif git rev-parse --verify "refs/heads/$default_branch" &>/dev/null; then
        target="refs/heads/$default_branch"
    else
        return 1
    fi

    # Ancestor: normal or fast-forward merge.
    if git merge-base --is-ancestor "refs/heads/$branch" "$target" 2>/dev/null; then
        return 0
    fi

    # Patch-equivalent: squash or rebase merge. git cherry marks each commit
    # on $branch with '+' if absent from $target or '-' if already applied.
    local output
    output=$(git cherry "$target" "refs/heads/$branch" 2>/dev/null) || return 1
    [[ -z "$output" ]] && return 1
    if ! grep -q '^+' <<< "$output"; then
        return 0
    fi

    return 1
}

# Check if the PR for a branch has been merged on GitHub.
# Requires the gh CLI; returns non-zero (treated as "not merged") if gh is
# unavailable, no PR exists for the branch, or the PR is still open/closed.
is_branch_pr_merged() {
    local branch="$1"
    command -v gh &>/dev/null || return 1

    local state
    state=$(gh pr view "$branch" --json state --jq .state 2>/dev/null) || return 1
    [[ "$state" == "MERGED" ]]
}

# Derive tmux session name from a worktree path
session_name_for_path() {
    local name
    name="$(basename "$1")"
    echo "${name//[.:]/-}"
}

# Kill the tmux session associated with a worktree path.
# If we're currently in that session, switch to the main repo session first.
kill_worktree_tmux_session() {
    local wt_path="$1"
    local main_worktree="$2"

    [[ -z "${TMUX:-}" ]] && return

    local session_name
    session_name=$(session_name_for_path "$wt_path")

    if ! tmux has-session -t "=$session_name" 2>/dev/null; then
        return
    fi

    # If we're in the session being killed, switch to main repo session first
    local current_session
    current_session=$(tmux display-message -p '#S')
    if [[ "$current_session" == "$session_name" ]]; then
        local main_session
        main_session=$(session_name_for_path "$main_worktree")
        # Create main session if it doesn't exist
        if ! tmux has-session -t "=$main_session" 2>/dev/null; then
            tmux new-session -d -s "$main_session" -c "$main_worktree"
        fi
        tmux switch-client -t "=$main_session"
    fi

    tmux kill-session -t "=$session_name"
    echo "Killed tmux session: $session_name"
}

# Move the *interactive* shell to a new directory. gwt runs as a child process,
# so it can't cd its parent; instead the gwt() shell wrapper (in .zshrc_alias)
# passes a temp path via $GWT_CD_FILE and cds there after we exit. Falls back to
# the tmux send-keys hack when invoked directly without that wrapper.
emit_cd() {
    local dest="$1"
    if [[ -n "${GWT_CD_FILE:-}" ]]; then
        printf '%s\n' "$dest" > "$GWT_CD_FILE"
    elif [[ -n "${TMUX:-}" ]]; then
        tmux send-keys "cd '$dest'" Enter
    fi
}

# Run the repo's .gwt-setup script for a freshly created worktree, detached and
# in the background so the session opens immediately instead of blocking on it.
# Output goes to <worktree>/.gwt-setup.log (git-ignored globally); nohup +
# redirected stdio keep it alive past gwt's exit and any pane detach.
run_setup_script() {
    local worktree_path="$1"
    local main_worktree
    main_worktree=$(get_main_worktree)
    local setup_script="${main_worktree}/.gwt-setup"

    [[ -f "$setup_script" ]] || return 0

    local log="${worktree_path}/.gwt-setup.log"
    echo "Running setup script in background: $setup_script"
    echo "  logs -> $log  (tail -f '$log')"

    if [[ -x "$setup_script" ]]; then
        nohup bash -c 'cd "$1" && exec "$2"' _ "$worktree_path" "$setup_script" >"$log" 2>&1 &
    else
        nohup bash -c 'cd "$1" && exec bash "$2"' _ "$worktree_path" "$setup_script" >"$log" 2>&1 &
    fi
    disown 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_switch() {
    # Join all arguments with hyphens: "gwt switch a b c" → "a-b-c"
    local input="${*}"
    input="${input// /-}"

    # No argument — fzf picker over existing worktrees
    if [[ -z "$input" ]]; then
        local main_worktree
        main_worktree=$(get_main_worktree)

        # Display column (field 1) shows the worktree dir name and its branch,
        # with a "(main)" marker for the primary worktree; fields 2/3 hold the
        # raw branch/path for the cut calls below.
        local selected
        selected=$(git worktree list --porcelain | awk -v main="$main_worktree" '
            /^worktree / { wt = substr($0, 10) }
            /^branch /   {
                b = substr($0, 8); sub(/^refs\/heads\//, "", b);
                n = split(wt, parts, "/"); dir = parts[n];
                if (length(dir) > 28) dir = substr(dir, 1, 26) "..";
                marker = (wt == main) ? " (main)" : "";
                disp = sprintf("%-28s %s%s", dir, b, marker);
                print disp "\t" b "\t" wt
            }
        ' | fzf --delimiter='\t' --with-nth=1 --preview 'echo {3}' --prompt="Switch to worktree> ")

        if [[ -z "$selected" ]]; then
            return
        fi

        local branch wt_path
        branch=$(echo "$selected" | cut -f2)
        wt_path=$(echo "$selected" | cut -f3)

        open_session "$branch" "$wt_path"
        return
    fi

    # Argument given — create worktree if needed, then switch.
    # PR references (pull URL, #N, or a bare PR number) resolve to the PR's
    # head branch via resolve_branch, so they open a normal branch worktree.
    local branch
    branch=$(resolve_branch "$input") || exit 1
    if [[ "$branch" != "$input" ]]; then
        echo "Resolved $input → $branch"
    fi

    local main_worktree
    main_worktree=$(get_main_worktree)
    local repo
    repo=$(basename "$main_worktree")

    # Check if a worktree already exists for this branch
    local existing_wt
    existing_wt=$(find_worktree_for_branch "$branch")

    if [[ -n "$existing_wt" ]]; then
        # Worktree exists — open it in a tmux session
        echo "Worktree already exists: $existing_wt"
        open_session "$branch" "$existing_wt"
        return
    fi

    # Worktree path: nested under a per-repo dir, with '/' in the branch flattened
    # so "feat/foo" → "<repo>/feat-foo" (one dir per branch, not deeper nesting).
    local branch_slug="${branch//\//-}"
    local wt_root
    wt_root=$(worktrees_dir)
    local wt_path="${wt_root}/${repo}/${branch_slug}"

    # Path already exists on disk (e.g. stale/deregistered worktree) — just open it
    if [[ -d "$wt_path" ]]; then
        wt_path=$(cd "$wt_path" && pwd)
        echo "Directory already exists: $wt_path"
        open_session "$branch" "$wt_path"
        return
    fi

    # Check if branch exists (locally or in origin)
    if git show-ref --verify --quiet "refs/heads/${branch}" 2>/dev/null; then
        # Local branch exists — create worktree from it
        git worktree add "$wt_path" "$branch"
    elif git fetch origin "$branch" 2>/dev/null && \
         git show-ref --verify --quiet "refs/remotes/origin/${branch}" 2>/dev/null; then
        # Remote branch exists — create worktree tracking it
        git worktree add "$wt_path" "$branch"
    else
        # Branch doesn't exist — create from the current branch (fall back to
        # the default branch if HEAD is detached or unavailable).
        local base
        base=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
        if [[ -z "$base" || "$base" == "HEAD" ]]; then
            base=$(get_default_branch)
        fi
        git worktree add -b "$branch" "$wt_path" "$base"
    fi

    # Resolve to absolute path
    wt_path=$(cd "$wt_path" && pwd)

    # Run setup script for new worktrees
    run_setup_script "$wt_path"

    # Open in tmux
    open_session "$branch" "$wt_path"
}

cmd_delete() {
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=1; shift ;;
            *) echo "Unknown option: $1"; exit 1 ;;
        esac
    done

    local main_worktree
    main_worktree=$(get_main_worktree)
    local current_dir
    current_dir=$(pwd)

    # Build list of secondary worktrees for fzf
    local worktrees
    worktrees=$(git worktree list --porcelain | awk -v main="$main_worktree" '
        /^worktree / { wt = substr($0, 10) }
        /^branch /   { b = substr($0, 8); sub(/^refs\/heads\//, "", b); if (wt != main) print b "\t" wt }
    ')

    if [[ -z "$worktrees" ]]; then
        echo "No secondary worktrees to delete"
        exit 0
    fi

    # Find current worktree's branch to use as fzf default
    local current_branch=""
    while IFS=$'\t' read -r b wt; do
        if [[ "$current_dir" == "$wt"* ]]; then
            current_branch="$b"
            break
        fi
    done <<< "$worktrees"

    local fzf_opts=(--delimiter='\t' --with-nth=1 --prompt="Delete worktree> ")
    if [[ -n "$current_branch" ]]; then
        fzf_opts+=(--query="$current_branch" --select-1)
    fi

    local selected
    selected=$(echo "$worktrees" | fzf "${fzf_opts[@]}")

    if [[ -z "$selected" ]]; then
        return
    fi

    local branch wt_path
    branch=$(echo "$selected" | cut -f1)
    wt_path=$(echo "$selected" | cut -f2)

    echo "Removing worktree: $wt_path (branch: $branch)"

    # Remove the worktree + tear down its session (native herdr path when
    # possible, git fallback otherwise). Keeps the branch.
    remove_worktree "$wt_path" "$main_worktree" "$force" || return
}

cmd_setup() {
    local main_worktree
    main_worktree=$(get_main_worktree)
    local setup_script="${main_worktree}/.gwt-setup"

    "${EDITOR:-vim}" "$setup_script"
}

cmd_purge() {
    local main_worktree
    main_worktree=$(get_main_worktree)
    local default_branch
    default_branch=$(get_default_branch)

    # Refresh origin/<default> so squash-merged branches are detected.
    echo "Fetching origin/$default_branch..."
    git fetch origin "$default_branch" 2>/dev/null || true

    local entries=()
    while IFS=$'\t' read -r branch wt; do
        [[ -z "$branch" ]] && continue
        [[ "$wt" == "$main_worktree" ]] && continue
        [[ "$branch" == "$default_branch" ]] && continue

        # Merged locally (fast/ancestor or squash/rebase patch-equivalence),
        # or its PR has been merged on GitHub. The local check runs first so
        # the gh network call is only made when needed.
        if is_branch_merged "$branch" "$default_branch" || is_branch_pr_merged "$branch"; then
            entries+=("$branch"$'\t'"$wt")
        fi
    done < <(git worktree list --porcelain | awk '
        /^worktree / { wt = substr($0, 10) }
        /^branch /   { b = substr($0, 8); sub(/^refs\/heads\//, "", b); print b "\t" wt }
    ')

    if [[ ${#entries[@]} -eq 0 ]]; then
        echo "No merged worktrees to purge"
        return
    fi

    echo
    echo "Worktrees whose branch (or its PR) is merged into $default_branch:"
    for entry in "${entries[@]}"; do
        local b="${entry%%$'\t'*}"
        local w="${entry##*$'\t'}"
        printf "  %s  →  %s\n" "$b" "$w"
    done
    echo

    local reply
    read -rp "Remove these worktrees and delete their branches? (y/N) " reply
    if [[ "$reply" != "y" && "$reply" != "Y" ]]; then
        echo "Aborted"
        return
    fi

    # Remove each worktree + tear down its session. The one we're sitting in (if
    # any) goes LAST: native herdr removal of the current workspace can tear down
    # this pane and kill gwt mid-loop, so purge the others first. Branches were
    # verified merged above, so force-removal and force branch-delete are safe.
    local current_dir current_entry=""
    current_dir=$(pwd)
    for entry in "${entries[@]}"; do
        local w="${entry##*$'\t'}"
        if [[ "$current_dir" == "$w"* ]]; then current_entry="$entry"; continue; fi
        local b="${entry%%$'\t'*}"
        echo "Removing worktree: $w"
        remove_worktree "$w" "$main_worktree" 1 || continue
        git -C "$main_worktree" branch -D "$b" 2>/dev/null || true
    done

    if [[ -n "$current_entry" ]]; then
        local b="${current_entry%%$'\t'*}"
        local w="${current_entry##*$'\t'}"
        echo "Removing worktree: $w"
        remove_worktree "$w" "$main_worktree" 1 || return
        # Native removal of our own workspace may kill gwt before this runs; the
        # branch can only be dropped after removal (it's checked out until then),
        # so a merged branch that lingers here is harmless — the next purge or
        # clean-gone will delete it.
        git -C "$main_worktree" branch -D "$b" 2>/dev/null || true
    fi
}

# ---------------------------------------------------------------------------
# Multiplexer session integration
#
# gwt drives either tmux or herdr, depending on where it runs. Each worktree
# gets its own session (tmux) / workspace (herdr); the dispatchers below pick
# the right backend so `switch`/`delete`/`purge` work in both.
# ---------------------------------------------------------------------------

in_herdr() { [[ -n "${HERDR_PANE_ID:-}" ]]; }

# Create or focus a session/workspace for a worktree.
open_session() {
    if in_herdr; then open_in_herdr "$@"; else open_in_tmux "$@"; fi
}

# Tear down the session/workspace associated with a worktree path.
close_worktree_session() {
    if in_herdr; then close_worktree_herdr "$@"; else kill_worktree_tmux_session "$@"; fi
}

# Remove a worktree's checkout and tear down its multiplexer session.
#
# In herdr, first try the native `herdr worktree remove`: for a herdr-managed
# worktree it removes the git worktree, closes the workspace, and refocuses the
# parent repo — atomically, server-side, keeping the branch. Because it's one
# server call, gwt doesn't need to outlive the pane teardown (this is what makes
# the setsid-daemon dance in close_worktree_herdr unnecessary here). It refuses
# a dirty worktree unless force=1, mirroring `git worktree remove`.
#
# Anything herdr doesn't manage as a worktree (Claude Code's .claude/worktrees
# spaces, plain workspaces), tmux, or any native failure (incl. dirty-without
# -force) falls through to `git worktree remove` + close_worktree_session.
#
# The caller deletes the branch afterwards if it wants to — native remove keeps
# it. Args: <wt_path> <main_worktree> <force:0|1>. Returns non-zero if removal
# failed (e.g. dirty without force).
remove_worktree() {
    local wt_path="$1" main_worktree="$2" force="$3"

    if in_herdr; then
        local abs wsid
        abs=$(cd "$wt_path" 2>/dev/null && pwd || echo "$wt_path")
        wsid=$(herdr_workspace_for_path "$abs")
        if [[ -n "$wsid" ]]; then
            local args=(--workspace "$wsid")
            [[ "$force" == "1" ]] && args+=(--force)
            # Success closes the workspace, which may kill this pane (and gwt)
            # mid-call — but the removal+refocus already happened server-side, so
            # that's a clean outcome. Only a genuine failure returns here without
            # a result, and it leaves the worktree untouched → git fallback.
            if herdr worktree remove "${args[@]}" --json 2>&1 | grep -q '"result"'; then
                return 0
            fi
        fi
    fi

    # --- git + session-teardown fallback ---
    unlock_worktree "$wt_path"
    local remove_args=("$wt_path")
    [[ "$force" == "1" ]] && remove_args=(--force "$wt_path")

    # If we're inside the worktree being removed, jump to main first.
    if [[ "$(pwd)" == "$wt_path"* ]]; then
        cd "$main_worktree"
        git worktree remove "${remove_args[@]}" || return 1
        emit_cd "$main_worktree"
    else
        git worktree remove "${remove_args[@]}" || return 1
    fi
    close_worktree_session "$wt_path" "$main_worktree"
}

open_in_tmux() {
    local branch="$1"
    local wt_path="$2"

    local session_name
    session_name=$(session_name_for_path "$wt_path")

    if [[ -z "${TMUX:-}" ]]; then
        # Not in tmux — create or attach to session
        if tmux has-session -t "=$session_name" 2>/dev/null; then
            tmux attach-session -t "=$session_name"
        else
            tmux new-session -d -s "$session_name" -c "$wt_path"
            tmux attach-session -t "=$session_name"
        fi
        return
    fi

    # Already in tmux — create or switch to session
    if tmux has-session -t "=$session_name" 2>/dev/null; then
        tmux switch-client -t "=$session_name"
    else
        tmux new-session -d -s "$session_name" -c "$wt_path"
        tmux switch-client -t "=$session_name"
    fi
}

# Find the herdr workspace already rooted at a worktree path. Match first on the
# git checkout path herdr tracks per workspace (robust), then fall back to the
# dir-basename label (workspaces opened before herdr indexed the worktree).
herdr_workspace_for_path() {
    local wt_path="$1" label
    label=$(basename "$wt_path")
    herdr workspace list 2>/dev/null | jq -r --arg p "$wt_path" --arg l "$label" '
        (.result.workspaces // [])
        | ( map(select(.worktree.checkout_path == $p))
          + map(select(.label == $l)) )
        | (.[0].workspace_id // empty)'
}

open_in_herdr() {
    local branch="$1"
    local wt_path="$2"

    wt_path=$(cd "$wt_path" && pwd)
    local label
    label=$(basename "$wt_path")

    # Open it as a native herdr worktree so herdr tracks the git checkout (badge,
    # worktree list, remove confirmation) instead of a generic space. Idempotent:
    # herdr reconciles by checkout path, focusing the existing workspace — and
    # upgrading a plain space's metadata — if it's already open.
    #
    # --cwd the main worktree: herdr rejects worktree open/create actions whose
    # source is a *linked* worktree (error "linked_worktree_source"), so anchor
    # the call to the repo's parent workspace instead of gwt's caller — otherwise
    # it fails whenever invoked from a secondary worktree. The `|| true` keeps a
    # non-zero exit from aborting gwt under `set -e` so the fallback below runs.
    local main_worktree created wsid
    main_worktree=$(get_main_worktree)
    created=$(herdr worktree open --cwd "$main_worktree" --path "$wt_path" --label "$label" --focus --json 2>/dev/null) || true
    wsid=$(printf '%s' "$created" | jq -r '.result.workspace.workspace_id // empty')

    # Fall back to a plain space if the path isn't a registered git worktree
    # (e.g. a stale directory) or `worktree open` is unavailable.
    if [[ -z "$wsid" ]]; then
        herdr workspace create --cwd "$wt_path" --label "$label" --focus >/dev/null 2>&1 || true
    fi
}

# Close the herdr workspace associated with a worktree path. Mirrors
# kill_worktree_tmux_session: when closing the workspace we're currently in,
# land back on the main repo's workspace instead of an arbitrary neighbour.
#
# Two herdr quirks force the approach below:
#   1. `workspace focus` before a close doesn't stick — closing a workspace makes
#      herdr re-home to the newest remaining one regardless. So the refocus must
#      happen *after* the close.
#   2. Closing our own workspace tears down the pane gwt runs in and kills every
#      process still living in it — including a `& disown` background job, which
#      stays in the pane's process group. So the close+refocus must be *fully*
#      detached (double-fork + setsid → new session, no controlling terminal) to
#      outlive the pane. macOS has no setsid(1), so we daemonize via python3.
close_worktree_herdr() {
    local wt_path="$1"
    local main_worktree="${2:-}"
    wt_path=$(cd "$wt_path" 2>/dev/null && pwd || echo "$wt_path")
    local wsid
    wsid=$(herdr_workspace_for_path "$wt_path")
    [[ -z "$wsid" ]] && return

    # Are we closing the workspace gwt itself is running in? Derive the current
    # workspace id from HERDR_PANE_ID (e.g. "w36:p1" → "w36"). This is reliable
    # regardless of focus state or whether the checkout still exists — unlike the
    # UI-global `.focused` flag, which by the time we get here has already moved
    # off the just-removed worktree, so the refocus-to-main branch never ran.
    local current_wsid="${HERDR_PANE_ID%%:*}"

    local main_id=""
    if [[ -n "$current_wsid" && "$wsid" == "$current_wsid" && -n "$main_worktree" ]]; then
        main_id=$(herdr_workspace_for_path "$(cd "$main_worktree" && pwd)")
        # Ensure the main repo's workspace exists so the detached refocus below
        # has a target (open_in_herdr creates it if missing).
        if [[ -z "$main_id" ]]; then
            open_in_herdr "" "$main_worktree"
            main_id=$(herdr_workspace_for_path "$(cd "$main_worktree" && pwd)")
        fi
    fi

    if [[ -n "$main_id" ]] && command -v python3 >/dev/null 2>&1; then
        # Fully detached daemon (double-fork + setsid): closing our own workspace
        # kills everything left in this pane's process group, so a plain
        # `& disown` job dies before it can refocus. A new session survives it.
        # The brief sleep lets gwt return and the pane settle before the close.
        python3 -c '
import os, sys, time, subprocess
if os.fork() != 0: os._exit(0)
os.setsid()
if os.fork() != 0: os._exit(0)
time.sleep(0.4)
subprocess.run(["herdr", "workspace", "close", sys.argv[1]])
subprocess.run(["herdr", "workspace", "focus", sys.argv[2]])
' "$wsid" "$main_id" </dev/null >/dev/null 2>&1
        echo "Closing herdr workspace $wsid; returning to $(basename "$main_worktree")"
    else
        herdr workspace close "$wsid" >/dev/null 2>&1
        echo "Closed herdr workspace: $wsid"
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

# Ensure we're in a git repo
if ! git rev-parse --git-dir &>/dev/null; then
    echo "Error: not inside a git repository"
    exit 1
fi

show_help() {
    echo "Usage: gwt <command> [args]"
    echo ""
    echo "Commands:"
    echo "  gwt switch [ref]  Switch to a worktree (fzf picker if no ref given)."
    echo "                    Creates the worktree if it doesn't exist."
    echo "                    <ref> may be a branch name, #PR, or PR URL"
    echo "                    (PR refs resolve to the PR's head branch)."
    echo "  gwt delete [-f]   Pick a worktree with fzf and remove it"
    echo "                    -f/--force removes even with uncommitted changes"
    echo "  gwt purge         Remove worktrees whose branches are merged"
    echo "  gwt setup         Open .gwt-setup in \$EDITOR"
    echo ""
    echo "Setup:"
    echo "  Place a .gwt-setup script in your repo root. It runs automatically"
    echo "  in the background on new worktrees; output -> .gwt-setup.log"
}

case "${1:-}" in
    switch)        shift; cmd_switch "$@" ;;
    setup)         shift; cmd_setup "$@" ;;
    delete)        shift; cmd_delete "$@" ;;
    purge)         shift; cmd_purge "$@" ;;
    -h|--help|"")  show_help ;;
    *)
        echo "Unknown command: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
