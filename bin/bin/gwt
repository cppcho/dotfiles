#!/usr/bin/env bash
# Git worktree + tmux workflow helper
#
# Usage:
#   gwt switch [branch|#N|pr-url]  Switch to a worktree (fzf picker if no arg, create if needed)
#   gwt delete [--force]            Pick a worktree with fzf and remove it
#   gwt purge                      Remove worktrees whose branches are merged
#   gwt setup                      Open .gwt-setup in the repo root with $EDITOR
#
# Setup script:
#   Place a `.gwt-setup` file in your repo root (git-ignored).
#   It runs automatically when a new worktree is created.

set -e

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

get_main_worktree() {
    git worktree list --porcelain | head -1 | sed 's/^worktree //'
}

get_default_branch() {
    if git show-ref --verify --quiet refs/heads/main 2>/dev/null; then
        echo "main"
    elif git show-ref --verify --quiet refs/heads/master 2>/dev/null; then
        echo "master"
    else
        echo "Error: could not find main or master branch" >&2
        exit 1
    fi
}

# Find existing worktree path for a given branch name
find_worktree_for_branch() {
    local branch="$1"
    git worktree list --porcelain | awk -v branch="$branch" '
        /^worktree / { wt = substr($0, 10) }
        /^branch /   { b = substr($0, 8); sub(/^refs\/heads\//, "", b); if (b == branch) print wt }
    '
}

# Resolve a user-supplied ref to a branch name.
# Accepts a branch name, a PR number (#123 or 123), or a GitHub PR URL.
resolve_branch() {
    local input="$1"
    local pr_num=""

    # GitHub PR URL: https://github.com/owner/repo/pull/123
    if [[ "$input" =~ github\.com/[^/]+/[^/]+/pull/([0-9]+) ]]; then
        pr_num="${BASH_REMATCH[1]}"
    # Explicit PR form: #123
    elif [[ "$input" =~ ^#([0-9]+)$ ]]; then
        pr_num="${BASH_REMATCH[1]}"
    # Bare number: try as PR first, fall back to literal branch name
    elif [[ "$input" =~ ^[0-9]+$ ]]; then
        pr_num="$input"
    fi

    if [[ -n "$pr_num" ]]; then
        if ! command -v gh &>/dev/null; then
            if [[ "$input" != "$pr_num" ]]; then
                echo "Error: gh CLI is required to resolve PR $input" >&2
                return 1
            fi
        else
            local branch
            if branch=$(gh pr view "$pr_num" --json headRefName --jq .headRefName 2>/dev/null) \
                && [[ -n "$branch" ]]; then
                echo "$branch"
                return 0
            fi
            # Explicit PR syntax must resolve; bare number can fall through as branch
            if [[ "$input" != "$pr_num" ]]; then
                echo "Error: could not resolve PR $input via gh" >&2
                return 1
            fi
        fi
    fi

    echo "$input"
    return 0
}

# Echo the PR number if the input is a PR reference (a github pull URL, #N, or a
# bare number that gh confirms is a PR), else return non-zero. The gh call only
# fires for a bare number, so branch names never pay for it.
pr_number_from_input() {
    local input="$1"
    if [[ "$input" =~ github\.com/[^/]+/[^/]+/pull/([0-9]+) ]]; then
        echo "${BASH_REMATCH[1]}"
    elif [[ "$input" =~ ^#([0-9]+)$ ]]; then
        echo "${BASH_REMATCH[1]}"
    elif [[ "$input" =~ ^([0-9]+)$ ]] \
        && command -v gh &>/dev/null \
        && gh pr view "${BASH_REMATCH[1]}" --json number &>/dev/null; then
        echo "${BASH_REMATCH[1]}"
    else
        return 1
    fi
}

# Check if a branch has been merged into the default branch.
# Handles fast-forward/merge commits (ancestor check) and squash/rebase
# merges (patch-equivalence via git cherry).
is_branch_merged() {
    local branch="$1"
    local default_branch="$2"

    # Prefer origin/<default> for freshness, fall back to local.
    local target=""
    if git rev-parse --verify "refs/remotes/origin/$default_branch" &>/dev/null; then
        target="refs/remotes/origin/$default_branch"
    elif git rev-parse --verify "refs/heads/$default_branch" &>/dev/null; then
        target="refs/heads/$default_branch"
    else
        return 1
    fi

    # Ancestor: normal or fast-forward merge.
    if git merge-base --is-ancestor "refs/heads/$branch" "$target" 2>/dev/null; then
        return 0
    fi

    # Patch-equivalent: squash or rebase merge. git cherry marks each commit
    # on $branch with '+' if absent from $target or '-' if already applied.
    local output
    output=$(git cherry "$target" "refs/heads/$branch" 2>/dev/null) || return 1
    [[ -z "$output" ]] && return 1
    if ! grep -q '^+' <<< "$output"; then
        return 0
    fi

    return 1
}

# Check if the PR for a branch has been merged on GitHub.
# Requires the gh CLI; returns non-zero (treated as "not merged") if gh is
# unavailable, no PR exists for the branch, or the PR is still open/closed.
is_branch_pr_merged() {
    local branch="$1"
    command -v gh &>/dev/null || return 1

    local state
    state=$(gh pr view "$branch" --json state --jq .state 2>/dev/null) || return 1
    [[ "$state" == "MERGED" ]]
}

# Derive tmux session name from a worktree path
session_name_for_path() {
    local name
    name="$(basename "$1")"
    echo "${name//[.:]/-}"
}

# Kill the tmux session associated with a worktree path.
# If we're currently in that session, switch to the main repo session first.
kill_worktree_tmux_session() {
    local wt_path="$1"
    local main_worktree="$2"

    [[ -z "${TMUX:-}" ]] && return

    local session_name
    session_name=$(session_name_for_path "$wt_path")

    if ! tmux has-session -t "=$session_name" 2>/dev/null; then
        return
    fi

    # If we're in the session being killed, switch to main repo session first
    local current_session
    current_session=$(tmux display-message -p '#S')
    if [[ "$current_session" == "$session_name" ]]; then
        local main_session
        main_session=$(session_name_for_path "$main_worktree")
        # Create main session if it doesn't exist
        if ! tmux has-session -t "=$main_session" 2>/dev/null; then
            tmux new-session -d -s "$main_session" -c "$main_worktree"
        fi
        tmux switch-client -t "=$main_session"
    fi

    tmux kill-session -t "=$session_name"
    echo "Killed tmux session: $session_name"
}

run_setup_script() {
    local worktree_path="$1"
    local main_worktree
    main_worktree=$(get_main_worktree)
    local setup_script="${main_worktree}/.gwt-setup"

    if [[ -x "$setup_script" ]]; then
        echo "Running setup script: $setup_script"
        (cd "$worktree_path" && "$setup_script")
    elif [[ -f "$setup_script" ]]; then
        echo "Running setup script: $setup_script"
        (cd "$worktree_path" && bash "$setup_script")
    fi
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_switch() {
    # Join all arguments with hyphens: "gwt switch a b c" → "a-b-c"
    local input="${*}"
    input="${input// /-}"

    # No argument — fzf picker over existing worktrees
    if [[ -z "$input" ]]; then
        local main_worktree
        main_worktree=$(get_main_worktree)

        # Display column (field 1) carries a "(main)" marker for the primary
        # worktree; fields 2/3 hold the raw branch/path for the cut calls below.
        local selected
        selected=$(git worktree list --porcelain | awk -v main="$main_worktree" '
            /^worktree / { wt = substr($0, 10) }
            /^branch /   {
                b = substr($0, 8); sub(/^refs\/heads\//, "", b);
                disp = (wt == main) ? b " (main)" : b;
                print disp "\t" b "\t" wt
            }
        ' | fzf --delimiter='\t' --with-nth=1 --preview 'echo {3}' --prompt="Switch to worktree> ")

        if [[ -z "$selected" ]]; then
            return
        fi

        local branch wt_path
        branch=$(echo "$selected" | cut -f2)
        wt_path=$(echo "$selected" | cut -f3)

        open_in_tmux "$branch" "$wt_path"
        return
    fi

    # PR reference (pull URL, #N, or a bare number that resolves to a PR): open
    # it in review mode unless a review worktree already exists, in which case
    # just switch to it. Non-PR refs fall through to a normal branch worktree.
    local pr_num
    if pr_num=$(pr_number_from_input "$input"); then
        local review_branch="review/pr-${pr_num}"
        local existing_review
        existing_review=$(find_worktree_for_branch "$review_branch")
        if [[ -n "$existing_review" ]]; then
            echo "Review worktree exists: $existing_review"
            open_in_tmux "$review_branch" "$existing_review"
        else
            cmd_review "#${pr_num}"
        fi
        return
    fi

    # Argument given — create worktree if needed, then switch
    local branch
    branch=$(resolve_branch "$input") || exit 1
    if [[ "$branch" != "$input" ]]; then
        echo "Resolved $input → $branch"
    fi

    local main_worktree
    main_worktree=$(get_main_worktree)
    local repo
    repo=$(basename "$main_worktree")

    # Check if a worktree already exists for this branch
    local existing_wt
    existing_wt=$(find_worktree_for_branch "$branch")

    if [[ -n "$existing_wt" ]]; then
        # Worktree exists — open it in a tmux session
        echo "Worktree already exists: $existing_wt"
        open_in_tmux "$branch" "$existing_wt"
        return
    fi

    # Determine worktree path (flatten '/' so "feat/foo" → "repo-feat-foo", not nested)
    local branch_slug="${branch//\//-}"
    local wt_path="${main_worktree}/../${repo}-${branch_slug}"

    # Path already exists on disk (e.g. stale/deregistered worktree) — just open it
    if [[ -d "$wt_path" ]]; then
        wt_path=$(cd "$wt_path" && pwd)
        echo "Directory already exists: $wt_path"
        open_in_tmux "$branch" "$wt_path"
        return
    fi

    # Check if branch exists (locally or in origin)
    if git show-ref --verify --quiet "refs/heads/${branch}" 2>/dev/null; then
        # Local branch exists — create worktree from it
        git worktree add "$wt_path" "$branch"
    elif git fetch origin "$branch" 2>/dev/null && \
         git show-ref --verify --quiet "refs/remotes/origin/${branch}" 2>/dev/null; then
        # Remote branch exists — create worktree tracking it
        git worktree add "$wt_path" "$branch"
    else
        # Branch doesn't exist — create from the current branch (fall back to
        # the default branch if HEAD is detached or unavailable).
        local base
        base=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
        if [[ -z "$base" || "$base" == "HEAD" ]]; then
            base=$(get_default_branch)
        fi
        git worktree add -b "$branch" "$wt_path" "$base"
    fi

    # Resolve to absolute path
    wt_path=$(cd "$wt_path" && pwd)

    # Run setup script for new worktrees
    run_setup_script "$wt_path"

    # Open in tmux
    open_in_tmux "$branch" "$wt_path"
}

# Review a PR in a throwaway worktree + tmux session. Unlike `switch` (which
# checks out a branch to work on), this surfaces the whole PR as one unstaged
# diff: the worktree starts at the PR head, then HEAD/index reset to the
# merge-base, so fugitive's status shows every PR change reviewable with dv/=.
# Fetches the head via refs/pull/<n>/head so fork PRs work too.
cmd_review() {
    local input="${*// /}"
    if [[ -z "$input" ]]; then
        echo "Usage: gwt review <#PR|url|number>" >&2
        exit 1
    fi
    command -v gh &>/dev/null || { echo "Error: gh CLI required for review" >&2; exit 1; }

    local pr_num
    pr_num=$(pr_number_from_input "$input") \
        || { echo "Error: not a PR number/url: $input" >&2; exit 1; }

    local base
    base=$(gh pr view "$pr_num" --json baseRefName --jq .baseRefName 2>/dev/null) \
        || { echo "Error: gh pr view failed for #$pr_num" >&2; exit 1; }
    [[ -n "$base" ]] || { echo "Error: could not resolve base branch for #$pr_num" >&2; exit 1; }

    local main_worktree
    main_worktree=$(get_main_worktree)

    # Head via the GitHub pull ref (fork-safe); base from origin for the merge-base.
    git fetch origin "pull/${pr_num}/head" 2>/dev/null \
        || { echo "Error: failed to fetch head of PR #$pr_num" >&2; exit 1; }
    local head_sha
    head_sha=$(git rev-parse FETCH_HEAD)
    git fetch origin "$base" 2>/dev/null || true
    local mb
    mb=$(git merge-base "origin/${base}" "$head_sha" 2>/dev/null) || true
    [[ -n "$mb" ]] || { echo "Error: no merge-base with origin/$base" >&2; exit 1; }

    local branch="review/pr-${pr_num}"
    local wt_path="${main_worktree}/../review-pr-${pr_num}"

    # Recreate fresh each time so the review reflects the latest PR head.
    kill_worktree_tmux_session "$wt_path" "$main_worktree"
    local existing
    existing=$(find_worktree_for_branch "$branch")
    [[ -n "$existing" ]] && git worktree remove --force "$existing" 2>/dev/null || true
    git worktree prune
    git branch -D "$branch" 2>/dev/null || true
    [[ -d "$wt_path" ]] && rm -rf "$wt_path"

    git worktree add -b "$branch" "$wt_path" "$head_sha" \
        || { echo "Error: git worktree add failed" >&2; exit 1; }
    wt_path=$(cd "$wt_path" && pwd)
    git -C "$wt_path" reset --mixed "$mb"

    open_in_tmux "$branch" "$wt_path" "nvim -c 'topleft 12split | 0Git'"
}

cmd_delete() {
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=1; shift ;;
            *) echo "Unknown option: $1"; exit 1 ;;
        esac
    done

    local main_worktree
    main_worktree=$(get_main_worktree)
    local current_dir
    current_dir=$(pwd)

    # Build list of secondary worktrees for fzf
    local worktrees
    worktrees=$(git worktree list --porcelain | awk -v main="$main_worktree" '
        /^worktree / { wt = substr($0, 10) }
        /^branch /   { b = substr($0, 8); sub(/^refs\/heads\//, "", b); if (wt != main) print b "\t" wt }
    ')

    if [[ -z "$worktrees" ]]; then
        echo "No secondary worktrees to delete"
        exit 0
    fi

    # Find current worktree's branch to use as fzf default
    local current_branch=""
    while IFS=$'\t' read -r b wt; do
        if [[ "$current_dir" == "$wt"* ]]; then
            current_branch="$b"
            break
        fi
    done <<< "$worktrees"

    local fzf_opts=(--delimiter='\t' --with-nth=1 --prompt="Delete worktree> ")
    if [[ -n "$current_branch" ]]; then
        fzf_opts+=(--query="$current_branch" --select-1)
    fi

    local selected
    selected=$(echo "$worktrees" | fzf "${fzf_opts[@]}")

    if [[ -z "$selected" ]]; then
        return
    fi

    local branch wt_path
    branch=$(echo "$selected" | cut -f1)
    wt_path=$(echo "$selected" | cut -f2)

    echo "Removing worktree: $wt_path (branch: $branch)"

    local remove_args=("$wt_path")
    if [[ "$force" == "1" ]]; then
        remove_args=(--force "$wt_path")
    fi

    # If we're inside the worktree being deleted, cd to main first
    if [[ "$current_dir" == "$wt_path"* ]]; then
        cd "$main_worktree"
        git worktree remove "${remove_args[@]}"
        echo "Switched to: $main_worktree"
        if [[ -n "${TMUX:-}" ]]; then
            tmux send-keys "cd '$main_worktree'" Enter
        fi
    else
        git worktree remove "${remove_args[@]}"
    fi

    # Review worktrees ride a synthetic review/* branch (see cmd_review) that has
    # no upstream — drop it too so they don't accumulate.
    if [[ "$branch" == review/* ]]; then
        git branch -D "$branch" 2>/dev/null || true
    fi

    # Kill associated tmux session (must be last — may kill our own process)
    kill_worktree_tmux_session "$wt_path" "$main_worktree"
}

cmd_setup() {
    local main_worktree
    main_worktree=$(get_main_worktree)
    local setup_script="${main_worktree}/.gwt-setup"

    "${EDITOR:-vim}" "$setup_script"
}

cmd_purge() {
    local main_worktree
    main_worktree=$(get_main_worktree)
    local default_branch
    default_branch=$(get_default_branch)

    # Refresh origin/<default> so squash-merged branches are detected.
    echo "Fetching origin/$default_branch..."
    git fetch origin "$default_branch" 2>/dev/null || true

    local entries=()
    while IFS=$'\t' read -r branch wt; do
        [[ -z "$branch" ]] && continue
        [[ "$wt" == "$main_worktree" ]] && continue
        [[ "$branch" == "$default_branch" ]] && continue

        # Merged locally (fast/ancestor or squash/rebase patch-equivalence),
        # or its PR has been merged on GitHub. The local check runs first so
        # the gh network call is only made when needed.
        if is_branch_merged "$branch" "$default_branch" || is_branch_pr_merged "$branch"; then
            entries+=("$branch"$'\t'"$wt")
        fi
    done < <(git worktree list --porcelain | awk '
        /^worktree / { wt = substr($0, 10) }
        /^branch /   { b = substr($0, 8); sub(/^refs\/heads\//, "", b); print b "\t" wt }
    ')

    if [[ ${#entries[@]} -eq 0 ]]; then
        echo "No merged worktrees to purge"
        return
    fi

    echo
    echo "Worktrees whose branch (or its PR) is merged into $default_branch:"
    for entry in "${entries[@]}"; do
        local b="${entry%%$'\t'*}"
        local w="${entry##*$'\t'}"
        printf "  %s  →  %s\n" "$b" "$w"
    done
    echo

    local reply
    read -rp "Remove these worktrees and delete their branches? (y/N) " reply
    if [[ "$reply" != "y" && "$reply" != "Y" ]]; then
        echo "Aborted"
        return
    fi

    # If we're inside one of the worktrees being removed, jump out first.
    local current_dir
    current_dir=$(pwd)
    local moved=0
    for entry in "${entries[@]}"; do
        local w="${entry##*$'\t'}"
        if [[ "$current_dir" == "$w"* ]]; then
            cd "$main_worktree"
            moved=1
            break
        fi
    done

    for entry in "${entries[@]}"; do
        local b="${entry%%$'\t'*}"
        local w="${entry##*$'\t'}"
        echo "Removing worktree: $w"
        if git worktree remove "$w" 2>/dev/null; then
            :
        else
            echo "  (worktree is dirty; retrying with --force)"
            git worktree remove --force "$w" || continue
        fi
        # Branch was verified as merged above, so force-delete is safe.
        git branch -D "$b" 2>/dev/null || true
    done

    if [[ "$moved" == "1" && -n "${TMUX:-}" ]]; then
        tmux send-keys "cd '$main_worktree'" Enter
    fi

    # Kill associated tmux sessions (must be last — may kill our own process)
    for entry in "${entries[@]}"; do
        local w="${entry##*$'\t'}"
        kill_worktree_tmux_session "$w" "$main_worktree"
    done
}

# ---------------------------------------------------------------------------
# Tmux session integration
# ---------------------------------------------------------------------------

open_in_tmux() {
    local branch="$1"
    local wt_path="$2"
    local start_cmd="${3:-}"  # optional command to run in a freshly created session

    local session_name
    session_name=$(session_name_for_path "$wt_path")

    if [[ -z "${TMUX:-}" ]]; then
        # Not in tmux — create or attach to session
        if tmux has-session -t "=$session_name" 2>/dev/null; then
            tmux attach-session -t "=$session_name"
        else
            tmux new-session -d -s "$session_name" -c "$wt_path"
            [[ -n "$start_cmd" ]] && tmux send-keys -t "=$session_name" "$start_cmd" Enter
            tmux attach-session -t "=$session_name"
        fi
        return
    fi

    # Already in tmux — create or switch to session
    if tmux has-session -t "=$session_name" 2>/dev/null; then
        tmux switch-client -t "=$session_name"
    else
        tmux new-session -d -s "$session_name" -c "$wt_path"
        [[ -n "$start_cmd" ]] && tmux send-keys -t "=$session_name" "$start_cmd" Enter
        tmux switch-client -t "=$session_name"
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

# Ensure we're in a git repo
if ! git rev-parse --git-dir &>/dev/null; then
    echo "Error: not inside a git repository"
    exit 1
fi

show_help() {
    echo "Usage: gwt <command> [args]"
    echo ""
    echo "Commands:"
    echo "  gwt switch [ref]  Switch to a worktree (fzf picker if no ref given)."
    echo "                    Creates the worktree if it doesn't exist."
    echo "                    <ref> may be a branch name, #PR, or PR URL."
    echo "  gwt review <pr>   Review a PR (#N or URL) in a throwaway worktree +"
    echo "                    tmux session: PR shown as one unstaged diff."
    echo "  gwt delete [-f]   Pick a worktree with fzf and remove it"
    echo "                    -f/--force removes even with uncommitted changes"
    echo "  gwt purge         Remove worktrees whose branches are merged"
    echo "  gwt setup         Open .gwt-setup in \$EDITOR"
    echo ""
    echo "Setup:"
    echo "  Place a .gwt-setup script in your repo root."
    echo "  It runs automatically when a new worktree is created."
}

case "${1:-}" in
    switch)        shift; cmd_switch "$@" ;;
    review)        shift; cmd_review "$@" ;;
    setup)         shift; cmd_setup "$@" ;;
    delete)        shift; cmd_delete "$@" ;;
    purge)         shift; cmd_purge "$@" ;;
    -h|--help|"")  show_help ;;
    *)
        echo "Unknown command: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
