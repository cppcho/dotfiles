alias vim='nvim'
alias vi='nvim'

alias ta='~/bin/tmux-sessionizer ~/dotfiles'
alias af='~/bin/tmux-sessionizer'
alias ts='~/bin/tmux-session-picker'
alias update='brew update; brew upgrade; brew cleanup'
alias k=kubectl
alias ag='rg'
alias c='_ ; claude'
alias ccr='claude --resume'
alias ccc='claude --continue'
alias gclone='~/bin/git-clone-dev'
alias _='[[ -n "$TMUX" ]] && cd "$(tmux display-message -p "#{session_path}")"'

# Open nvim straight into a PR review (:PRReview). Optional arg: PR number/url/branch; none -> picker.
ghr() {
  if [[ -n "$1" ]]; then
    nvim -c "PRReview $1"
  else
    nvim -c PRReview
  fi
}

# Tear down the worktree a :PRReview/:DiffReview created and cd back to where it
# started. Mirrors :ReviewRestore in nvim; the user's checkout is never touched.
ghrr() {
  local common marker scratch return_dir
  common=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || { echo "not a git repo"; return 1; }
  marker="$common/REVIEW_WT"
  [[ -f "$marker" ]] || { echo "No review to restore"; return 1; }
  scratch=$(sed -n 1p "$marker"); return_dir=$(sed -n 2p "$marker")
  [[ -n "$return_dir" && -d "$return_dir" ]] && cd "$return_dir"
  if [[ -n "$scratch" ]]; then
    git worktree remove --force "$scratch" 2>/dev/null || { git worktree prune; rm -rf "$scratch"; }
  fi
  rm -f "$marker"
  echo "Review worktree removed"
}

# Jump straight to the Claude-session picker (same popup as tmux prefix v),
# whether or not you're already inside tmux.
vv() {
  if [[ -n "$TMUX" ]]; then
    tmux display-popup -E -w 64% -h 64% "$HOME/bin/tmux-claude-sessions"
  else
    # A popup needs an attached client, so register a one-shot client-attached
    # hook (self-removing) and then attach — creating a session if none exists.
    tmux has-session 2>/dev/null || tmux new-session -d
    tmux set-hook -g client-attached \
      'display-popup -E -w 64% -h 64% "~/bin/tmux-claude-sessions" ; set-hook -gu client-attached' \; \
      attach
  fi
}

# Fuzzy-pick a directory from z's frecency list and cd into it.
zz() {
  local dir
  dir=$(z -l 2>&1 | sed "s/^[0-9.,]* *//; s|^$HOME|~|" | fzf --tac --no-sort --query "$*") && cd "${dir/#\~/$HOME}"
}

# URL encode a string
urlencode() { python3 -c "import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=''))" "$1"; }
